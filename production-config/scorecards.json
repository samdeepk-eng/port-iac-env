      },
      {
        "description": "Service must have a dedicated owning team — default team does not count",
        "identifier": "github_has_team",
        "level": "Bronze",
        "query": {
          "combinator": "and",
          "conditions": [
            {
              "operator": "isNotEmpty",
              "property": "$team"
            },
            {
              "operator": "doesNotContains",
              "property": "$team",
              "value": "default-team"
            },
            {
              "operator": "doesNotContains",
              "property": "$team",
              "value": "default_team"
            }
          ]
        },
        "title": "Has team assigned"
