      {
        "color": "gold",
        "title": "Gold"
      }
    ],
    "rules": [
      {
        "description": "The entity includes enough Slack metadata to trace back to the source message.",
        "identifier": "has_slack_source",
        "level": "Bronze",
        "query": {
          "combinator": "and",
          "conditions": [
            {
              "operator": "isNotEmpty",
              "property": "sourceChannelId"
            },
            {
              "operator": "isNotEmpty",
              "property": "sourceMessageTs"
            },
            {
              "operator": "isNotEmpty",
              "property": "rawMessage"
            }
          ]
        },
        "title": "Has Slack source"
      },
      {
        "description": "The request has a concise summary for triage and search.",
        "identifier": "has_summary",
        "level": "Silver",
        "query": {
          "combinator": "and",
          "conditions": [
            {
              "operator": "isNotEmpty",
              "property": "summary"
            }
          ]
        },
        "title": "Has normalized summary"
      },
      {
        "description": "The request has implementation target details and is marked ready for Cursor.",
        "identifier": "ready_for_cursor",
        "level": "Gold",
        "query": {
          "combinator": "and",
          "conditions": [
            {
              "operator": "=",
              "property": "status",
              "value": "ready_for_cursor"
            },
            {
              "operator": "isNotEmpty",
              "property": "acceptanceCriteria"
            },
            {
              "operator": "isNotEmpty",
              "property": "targetRepositoryUrl"
            },
            {
              "operator": "isNotEmpty",
              "property": "cursorPrompt"
            }
          ]
        },
        "title": "Ready for Cursor"
      }
    ],
