  {
    "createdAt": "2026-06-11T14:47:46.049Z",
    "createdBy": "user_H82lQjkBSpNIBqeS",
    "description": "Provision a new EC2 instance on AWS",
    "icon": "Server",
    "id": "action_AbmEQ736owbNktYJ",
    "identifier": "deploy_ec2",
    "invocationMethod": {
      "payload": {
        "action": "{{ .action.identifier }}",
        "context": {
          "blueprint": "{{ .action.blueprint }}",
          "entity": "{{ .entity.identifier }}",
          "runId": "{{ .run.id }}"
        },
        "payload": {
          "censoredProperties": "{{ .action.encryptedProperties }}",
          "entity": "{{ .entity }}",
          "properties": "{{ .inputs }}"
        },
        "resourceType": "run",
        "status": "TRIGGERED",
        "trigger": "{{ .trigger | {by, origin, at} }}"
      },
      "type": "KAFKA"
    },
    "publish": true,
    "requiredApproval": false,
    "title": "Deploy EC2 Instance",
    "trigger": {
      "blueprintIdentifier": "ec2_instance",
      "operation": "CREATE",
      "type": "self-service",
      "userInputs": {
        "order": [
          "instance_name",
          "instance_type",
          "region",
          "ami_id",
          "key_pair"
        ],
        "properties": {
          "ami_id": {
            "description": "The Amazon Machine Image ID to use",
            "title": "AMI ID",
            "type": "string"
          },
          "instance_name": {
            "description": "A name tag for the EC2 instance",
            "title": "Instance Name",
            "type": "string"
          },
          "instance_type": {
            "description": "The EC2 instance type",
            "enum": [
              "t2.micro",
              "t2.small",
              "t2.medium",
              "t3.micro",
              "t3.small",
              "t3.medium",
              "t3.large",
              "t3.xlarge",
              "m5.large",
              "m5.xlarge",
              "c5.large",
              "c5.xlarge"
            ],
            "title": "Instance Type",
            "type": "string"
          },
          "key_pair": {
            "description": "EC2 key pair for SSH access (optional)",
            "title": "Key Pair Name",
            "type": "string"
          },
          "region": {
            "description": "The AWS region to deploy into",
            "enum": [
              "us-east-1",
              "us-east-2",
              "us-west-1",
              "us-west-2",
              "eu-west-1",
              "eu-west-2",
              "eu-central-1",
              "ap-southeast-1",
              "ap-southeast-2",
              "ap-northeast-1"
            ],
            "title": "AWS Region",
            "type": "string"
          }
        },
        "required": [
          "instance_name",
          "instance_type",
          "region",
          "ami_id"
        ]
      }
    },
    "updatedAt": "2026-06-11T14:47:46.049Z",
    "updatedBy": "user_H82lQjkBSpNIBqeS"
  },
  {
    "createdAt": "2026-06-17T16:18:18.196Z",
    "createdBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E",
    "description": "Create a new issue in a Jira project",
    "icon": "Jira",
    "id": "action_wMo7UFJVqxuiQgcD",
    "identifier": "create_an_issue",
    "invocationMethod": {
      "agent": false,
      "body": {
        "fields": {
          "assignee": {
            "id": "{{.inputs.assignee.relations.jira_user}}"
          },
          "description": "{{.inputs.description}}",
          "issuetype": {
            "name": "{{.inputs.issue_type}}"
          },
          "project": {
            "key": "{{.inputs.project.identifier}}"
          },
          "summary": "{{.inputs.title}}"
        }
      },
      "headers": {
        "Authorization": "Bearer {{ .secrets.__JIRA_JIRA_ATLASSIAN_USER_TOKEN }}",
        "Content-Type": "application/json"
      },
      "method": "POST",
      "synchronized": true,
      "type": "WEBHOOK",
      "url": "https://api.atlassian.com/ex/jira/33f08530-afd8-42fd-82cc-1dd5ebfeece8/rest/api/2/issue"
    },
    "publish": true,
    "requiredApproval": false,
    "title": "Create an issue",
    "trigger": {
      "blueprintIdentifier": "jiraIssue",
      "operation": "CREATE",
      "type": "self-service",
      "userInputs": {
        "order": [
          "project",
          "issue_type",
          "title",
          "description",
          "assignee"
        ],
        "properties": {
          "assignee": {
            "blueprint": "_user",
            "dataset": {
              "combinator": "and",
              "rules": [
                {
                  "operator": "isNotEmpty",
                  "property": "jira_user_id"
                }
              ]
            },
            "format": "entity",
            "icon": "DefaultProperty",
            "title": "Assignee",
            "type": "string"
          },
          "description": {
            "format": "markdown",
            "icon": "DefaultProperty",
            "title": "Description",
            "type": "string"
          },
          "issue_type": {
            "enum": [
              "Bug",
              "Story",
              "Epic"
            ],
            "enumColors": {
              "Bug": "red",
              "Epic": "purple",
              "Story": "green"
            },
            "icon": "DefaultProperty",
            "title": "Issue type",
            "type": "string"
          },
          "project": {
            "blueprint": "jiraProject",
            "format": "entity",
            "icon": "DefaultProperty",
            "title": "Project",
            "type": "string"
          },
          "title": {
            "icon": "DefaultProperty",
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "project",
          "issue_type",
          "title"
        ]
      }
    },
    "updatedAt": "2026-06-17T16:18:18.690Z",
    "updatedBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E"
  },
  {
    "createdAt": "2026-06-17T16:18:18.280Z",
    "createdBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E",
    "description": "Set relations between Jira Issues and User",
    "id": "action_uxNmCbggOQ0GlzUd",
    "identifier": "set_jira_issue_user_relations",
    "invocationMethod": {
      "agent": false,
      "body": {
        "mapping": {
          "blueprint": "jiraIssue",
          "entity": {
            "identifier": ".identifier",
            "relations": {
              "assignee": "if \"{{ .event.diff.after.relations.jira_user }}\" == .relations.jira_user_assignee then \"{{ .event.context.entityIdentifier }}\" else .relations.assignee end",
              "reporter": "if \"{{ .event.diff.after.relations.jira_user }}\" == .relations.jira_user_reporter then \"{{ .event.context.entityIdentifier }}\" else .relations.reporter end"
            }
          },
          "filter": "\"{{ .event.diff.after.relations.jira_user }}\" as $item | ($item == .relations.jira_user_reporter) or (.relations.jira_user_assignee == $item)"
        },
        "sourceBlueprint": "jiraIssue"
      },
      "headers": {
        "Content-Type": "application/json",
        "RUN_ID": "{{ .run.id }}"
      },
      "method": "POST",
      "synchronized": true,
      "type": "WEBHOOK",
      "url": "https://api.us.getport.io/v1/migrations"
    },
    "publish": true,
    "title": "Set Jira Issue User relations",
    "trigger": {
      "condition": {
        "combinator": "and",
        "expressions": [
          ".diff.before.relations.jira_user != .diff.after.relations.jira_user",
          ".diff.after.relations.jira_user != null"
        ],
        "type": "JQ"
      },
      "event": {
        "blueprintIdentifier": "_user",
        "type": "ANY_ENTITY_CHANGE"
      },
      "type": "automation"
    },
    "updatedAt": "2026-06-17T16:18:18.280Z",
    "updatedBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E"
  }
]