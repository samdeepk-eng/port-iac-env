[
  {
    "createdAt": "2026-06-05T18:36:54.308Z",
    "createdBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E",
    "description": "Add members to an existing team",
    "icon": "Team",
    "id": "action_3fUyZ75Smirh7S1y",
    "identifier": "_onboard_existing_team",
    "invocationMethod": {
      "agent": false,
      "body": {
        "mapping": {
          "blueprint": "_user",
          "entity": {
            "identifier": ".identifier",
            "team": ".team + [\"{{ .entity.identifier }}\"] | unique"
          },
          "filter": ".identifier as $item | {{ .inputs.team_members | map(.identifier) }}  | any(. == $item)"
        },
        "sourceBlueprint": "_user"
      },
      "headers": {},
      "method": "POST",
      "synchronized": true,
      "type": "WEBHOOK",
      "url": "https://api.us.getport.io/v1/migrations"
    },
    "publish": true,
    "requiredApproval": false,
    "title": "Add team members ",
    "trigger": {
      "blueprintIdentifier": "_team",
      "operation": "DAY-2",
      "type": "self-service",
      "userInputs": {
        "properties": {
          "team_members": {
            "items": {
              "blueprint": "_user",
              "format": "entity",
              "type": "string"
            },
            "sort": {
              "order": "DESC",
              "property": "$title"
            },
            "title": "Team members",
            "type": "array"
          }
        }
      }
    },
    "updatedAt": "2026-06-05T18:36:54.962Z",
    "updatedBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E"
  },
  {
    "createdAt": "2026-06-05T18:36:54.535Z",
    "createdBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E",
    "description": "Register your user and connect it to your user in other tools",
    "icon": "User",
    "id": "action_ZiPKVfOxlWaaFAI7",
    "identifier": "_onboard_your_user",
    "invocationMethod": {
      "blueprintIdentifier": "_user",
      "mapping": {
        "icon": "DefaultBlueprint",
        "identifier": "{{.trigger.by.user.email}}",
        "properties": {},
        "relations": {
          "jira_user": "{{ .inputs.jira_user.identifier?         // .inputs.your_user.relations.jira_user }}"
        },
        "team": "{{.inputs.teams | (if . then map(.identifier) else [] end)}}"
      },
      "type": "UPSERT_ENTITY"
    },
    "publish": true,
    "requiredApproval": false,
    "title": "Register your user",
    "trigger": {
      "blueprintIdentifier": "_user",
      "operation": "CREATE",
      "type": "self-service",
      "userInputs": {
        "order": [
          "teams",
          "jira_user"
        ],
        "properties": {
          "jira_user": {
            "blueprint": "jiraUser",
            "format": "entity",
            "icon": "Jira",
            "sort": {
              "order": "ASC",
              "property": "emailAddress"
            },
            "title": "Jira user",
            "type": "string"
          },
          "teams": {
            "default": {
              "jqQuery": ".user.teamsIdentifiers"
            },
            "icon": "Team",
            "items": {
              "blueprint": "_team",
              "format": "entity",
              "type": "string"
            },
            "title": "Teams",
            "type": "array",
            "visible": true
          },
          "your_user": {
            "blueprint": "_user",
            "default": {
              "jqQuery": ".user.email"
            },
            "format": "entity",
            "title": "Your user",
            "type": "string",
            "visible": false
          }
        }
      }
    },
    "updatedAt": "2026-06-17T16:18:18.814Z",
    "updatedBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E"
  },
  {
    "createdAt": "2026-06-05T18:36:54.668Z",
    "createdBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E",
    "description": "Assign service ownership to an existing team",
    "icon": "Microservice",
    "id": "action_mqctJfY38UOwplxk",
    "identifier": "set_ownership",
    "invocationMethod": {
      "agent": false,
      "body": {
        "mapping": {
          "blueprint": "service",
          "entity": {
            "identifier": ".identifier",
            "team": ".relations.owning_teams + [\"{{ .entity.identifier }}\"] | unique"
          },
          "filter": ".identifier as $item | {{ .inputs.services_owned_by_this_team | map(.identifier) }} | any(. == $item)"
        },
        "sourceBlueprint": "service"
      },
      "headers": {
        "RUN_ID": "{{ .run.id }}"
      },
      "method": "POST",
      "synchronized": true,
      "type": "WEBHOOK",
      "url": "https://api.us.getport.io/v1/migrations"
    },
    "publish": true,
    "requiredApproval": false,
    "title": "Own services",
    "trigger": {
      "blueprintIdentifier": "_team",
      "operation": "DAY-2",
      "type": "self-service",
      "userInputs": {
        "properties": {
          "services_owned_by_this_team": {
            "icon": "DefaultProperty",
            "items": {
              "blueprint": "service",
              "format": "entity",
              "type": "string"
            },
            "title": "Services owned by this team",
            "type": "array"
          }
        },
        "required": [
          "services_owned_by_this_team"
        ]
      }
    },
    "updatedAt": "2026-06-05T18:36:55.563Z",
    "updatedBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E"
  },
  {
    "allowAnyoneToViewRuns": true,
    "createdAt": "2026-06-05T18:36:54.762Z",
    "createdBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E",
    "description": "Set relations between Teams and the \"default group\" when a Team without a parent team is updated",
    "icon": "Team",
    "id": "action_BnLfdgImeKd2xU4r",
    "identifier": "set_parent_team_relations",
    "invocationMethod": {
      "blueprintIdentifier": "_team",
      "mapping": {
        "identifier": "{{ .event.diff.after.identifier }}",
        "relations": {
          "parent_team": "default_group"
        }
      },
      "type": "UPSERT_ENTITY"
    },
    "publish": true,
    "title": "Set Parent Team relations",
    "trigger": {
      "condition": {
        "combinator": "and",
        "expressions": [
          ".diff.after != null",
          ".diff.after.properties.type != \"group\"",
          "(.diff.after.relations.parent_team == null) or (.diff.after.relations.parent_team == \"\")"
        ],
        "type": "JQ"
      },
      "event": {
        "blueprintIdentifier": "_team",
        "type": "ANY_ENTITY_CHANGE"
      },
      "type": "automation"
    },
    "updatedAt": "2026-06-05T18:36:54.762Z",
    "updatedBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E"
  },
  {
    "allowAnyoneToViewRuns": true,
    "createdAt": "2026-06-08T13:58:11.257Z",
    "createdBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E",
    "description": "Set relations between Deployments and services based on the Repository",
    "id": "action_UuaPoGvtCxDEVhs2",
    "identifier": "set_github_deployment_relations",
    "invocationMethod": {
      "agent": false,
      "body": {
        "mapping": {
          "blueprint": "deployment",
          "entity": {
            "identifier": ".identifier",
            "relations": {
              "service": "\"{{ .event.context.entityIdentifier }}\""
            }
          },
          "filter": ".relations.github_pull_request != null and .properties.github_repo_id == \"{{ .event.diff.after.relations.github_repository }}\""
        },
        "sourceBlueprint": "deployment"
      },
      "headers": {
        "Content-Type": "application/json",
        "RUN_ID": "{{ .run.id }}"
      },
      "method": "POST",
      "synchronized": true,
      "type": "WEBHOOK",
      "url": "https://api.us.getport.io/v1/migrations"
    },
    "publish": true,
    "title": "Set GitHub Deployment relations",
    "trigger": {
      "condition": {
        "combinator": "and",
        "expressions": [
          ".diff.before.relations.github_repository != .diff.after.relations.github_repository",
          ".diff.after.relations.github_repository != null"
        ],
        "type": "JQ"
      },
      "event": {
        "blueprintIdentifier": "service",
        "type": "ANY_ENTITY_CHANGE"
      },
      "type": "automation"
    },
    "updatedAt": "2026-06-08T13:58:11.257Z",
    "updatedBy": "MegR6H7QSDVEWKnGRV4vcBIyKepMIn7E"
  },
